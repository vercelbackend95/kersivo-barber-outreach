---
import BookingFlow from '../../components/booking/BookingFlow';
import { prisma } from '../../lib/db/client';
import '../../styles/tokens.css';
import '../../styles/global.css';
import '../../styles/components/buttons.css';
import '../../styles/components/booking.css';

const [services, barbers, barberServiceLinks] = await Promise.all([
  prisma.service.findMany({ where: { active: true }, orderBy: { createdAt: 'asc' } }),
  prisma.barber.findMany({
    where: { active: true },
    orderBy: [{ sortOrder: 'asc' }, { createdAt: 'asc' }]
  }),
  prisma.barberService.findMany({ select: { barberId: true, serviceId: true } })
]);
---
<html lang="en">
  <body>
    <main class="container page-wrap">
      <BookingFlow
        client:load
        services={services}
        barbers={barbers.map((barber) => ({
          id: barber.id,
          name: barber.name,
          serviceIds: barberServiceLinks.filter((link) => link.barberId === barber.id).map((link) => link.serviceId)
        }))}
      />
    </main>
  </body>
</html>